# Application
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173
WEB_APP_URL=http://localhost:5173
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=replace-with-at-least-32-char-secret
JWT_SECRET=replace-with-at-least-32-char-secret
ENCRYPTION_KEY=replace-with-at-least-32-char-secret
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_ENABLE_OUTLOOK_OAUTH=false

# Database (Neon - provided for dev)
DATABASE_URL=postgresql://username:password@host:port/database

# Queue
REDIS_URL=redis://redis:6379

# Storage (AWS S3)
STORAGE_PROVIDER=aws-s3
AWS_REGION=ap-south-1
S3_BUCKET=anvil-s3-bucket-235689194792-ap-south-1
S3_PREFIX=anvil/
S3_SIGNED_URL_TTL_SECONDS=900
S3_MAX_UPLOAD_MB=25
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# SiteSnap AI policy (optional)
SITE_SNAP_AI_PROVIDER=openai
SITE_SNAP_AI_MODEL=gpt-4.1-mini
SITE_SNAP_MIN_IMAGE_BYTES=51200
SITE_SNAP_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/heic,image/heif
SITE_SNAP_SAFETY_ALERT_MIN_CONFIDENCE_BPS=7000

# Budget policy + AI narratives (optional)
BUDGET_AI_PROVIDER=openai
BUDGET_AI_MODEL=gpt-4.1-mini
BUDGET_DEFAULT_ALERT_THRESHOLD_BPS=500

# Change Order routing policy (optional)
CHANGE_ORDER_APPROVAL_STAGES=pm_review,finance_review
CHANGE_ORDER_DEFAULT_STAGE_SLA_HOURS=48
CHANGE_ORDER_STAGE_SLA_HOURS=pm_review:24,finance_review:48

# SubConnect portal policy (optional)
PORTAL_ALLOW_PROJECT_CODE_REGISTRATION=true
SUBCONNECT_INVITATION_EXPIRY_HOURS=168
PORTAL_PASSWORD_RESET_EXPIRY_MINUTES=120

# OAuth / SmartMail providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:5173/auth/oauth/callback
SMARTMAIL_SYNC_LOOKBACK_MINUTES=30
SMARTMAIL_DEFAULT_SYNC_MAX_RESULTS=50

# Worker scheduler SmartMail cadence (optional)
SCHEDULER_SMARTMAIL_INTERVAL_MS=900000

# Optional SMTP
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional Resend
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=anvil <no-reply@your-domain.com>

# Optional Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_GROWTH=
STRIPE_PRICE_ID_ENTERPRISE=
