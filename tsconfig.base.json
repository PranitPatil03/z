{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@foreman/ai": ["packages/ai/src/index.ts"],
      "@foreman/db": ["packages/db/src/index.ts"],
      "@foreman/domain": ["packages/domain/src/index.ts"],
      "@foreman/types": ["packages/types/src/index.ts"],
      "@foreman/sdk": ["packages/sdk/src/index.ts"],
      "@foreman/ui": ["packages/ui/src/index.ts"]
    }
  }
}
