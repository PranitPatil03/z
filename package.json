{
  "name": "foreman",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm run dev:free-api-port && turbo run dev --parallel",
    "dev:free-api-port": "sh -c 'for port in 3001 5173; do for pid in $(lsof -ti tcp:$port -sTCP:LISTEN 2>/dev/null); do echo \"[dev] clearing port :$port (pid $pid)\"; kill -9 \"$pid\" 2>/dev/null || true; done; done'",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:backend": "turbo run test --filter=@foreman/api --filter=@foreman/worker",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "db:migrate": "pnpm --filter @foreman/api db:migrate",
    "db:generate": "pnpm --filter @foreman/api db:generate",
    "db:seed": "pnpm --filter @foreman/api db:seed",
    "db:seed:append": "pnpm --filter @foreman/api db:seed:append"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.4.4",
    "typescript": "^5.8.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
