{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BucketListShort",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:ListBucket",
        "s3:ListBucketMultipartUploads"
      ],
      "Resource": "arn:aws:s3:::foreman-prod-assets-235689194792",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "foreman/*"
          ]
        }
      }
    },
    {
      "Sid": "ObjectRWShort",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload",
        "s3:ListMultipartUploadParts",
        "s3:PutObjectTagging",
        "s3:GetObjectTagging"
      ],
      "Resource": "arn:aws:s3:::foreman-prod-assets-235689194792/foreman/*"
    }
  ]
}
