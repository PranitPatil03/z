{
  "name": "@foreman/worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --out-dir dist",
    "start": "node dist/index.js",
    "lint": "biome check src",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@foreman/ai": "workspace:*",
    "@foreman/db": "workspace:*",
    "@foreman/domain": "workspace:*",
    "bullmq": "^5.58.0",
    "drizzle-orm": "^0.44.7",
    "nodemailer": "^8.0.4",
    "pino": "^9.7.0",
    "redis": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/nodemailer": "^8.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
