{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "../../",
    "outDir": "dist",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "../../packages/ai/src/**/*.ts",
    "../../packages/db/src/**/*.ts",
