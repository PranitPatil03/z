{
  "name": "@foreman/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --out-dir dist",
    "start": "node dist/index.js",
    "lint": "biome check src",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.6",
    "@foreman/ai": "workspace:*",
    "@foreman/db": "workspace:*",
    "@foreman/domain": "workspace:*",
    "@foreman/types": "workspace:*",
    "@neondatabase/serverless": "^0.10.4",
    "bcrypt": "^5.1.1",
    "better-auth": "^1.5.6",
    "bullmq": "^5.58.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.44.7",
    "express": "^5.1.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.4",
    "openapi-types": "^12.1.3",
    "pino": "^9.7.0",
    "pino-http": "^10.0.0",
    "redis": "^5.7.0",
    "stripe": "^18.5.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.3.0",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.5",
    "supertest": "^7.2.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
